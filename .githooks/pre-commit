#!/bin/sh

# Pre-commit hook: format Go files

if ! command -v go &> /dev/null; then
    exit 0
fi

STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$')

if [ -z "$STAGED_GO_FILES" ]; then
    exit 0
fi

for file in $STAGED_GO_FILES; do
    if [ ! -f "$file" ]; then
        continue
    fi
    gofmt -s -w "$file"
    git add "$file"
done

UNFORMATTED=$(gofmt -l $STAGED_GO_FILES 2>/dev/null)
if [ -n "$UNFORMATTED" ]; then
    echo "ERROR: The following files are not properly formatted:"
    echo "$UNFORMATTED"
    echo "Please run 'gofmt -s -w' on these files and stage the changes."
    exit 1
fi

exit 0
